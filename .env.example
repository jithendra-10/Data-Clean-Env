# DataClean-Env — sample environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# ── Hugging Face Inference Router (default LLM provider) ─────────────────────
HF_TOKEN=hf_...
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct

# ── Optional: OpenAI baseline (baseline/agent.py) ────────────────────────────
OPENAI_API_KEY=

# ── Server config ────────────────────────────────────────────────────────────
PORT=7860
ENABLE_WEB_INTERFACE=true

# ── Remote agents (baseline/agent.py, baseline/llama_agent.py) ───────────────
DATACLEAN_URL=http://localhost:7860
